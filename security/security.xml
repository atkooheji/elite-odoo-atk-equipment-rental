<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_equipment_rental" model="ir.module.category">
        <field name="name">Equipment Rental</field>
        <field name="description">Helps you manage equipment rental operations, QMS controls, and MIS reporting.</field>
        <field name="sequence">10</field>
    </record>

    <record id="privilege_equipment_rental" model="res.groups.privilege">
        <field name="name">Rental Operations</field>
        <field name="category_id" ref="module_category_equipment_rental"/>
    </record>

    <record id="group_equipment_rental_user" model="res.groups">
        <field name="name">User: Logistics &amp; Operations</field>
        <field name="privilege_id" ref="privilege_equipment_rental"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_equipment_rental_manager" model="res.groups">
        <field name="name">Manager: Operations &amp; QC</field>
        <field name="privilege_id" ref="privilege_equipment_rental"/>
        <field name="implied_ids" eval="[(4, ref('group_equipment_rental_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_equipment_rental_finance" model="res.groups">
        <field name="name">Finance: Invoicing &amp; Deposits</field>
        <field name="privilege_id" ref="privilege_equipment_rental"/>
        <field name="implied_ids" eval="[(4, ref('group_equipment_rental_user'))]"/>
    </record>

    <!-- Multi-Company Rule -->
    <record id="equipment_rental_multi_company_rule" model="ir.rule">
        <field name="name">Equipment Rental Multi-Company</field>
        <field name="model_id" ref="model_equipment_rental"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
