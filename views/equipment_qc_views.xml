<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="equipment_qc_template_view_list" model="ir.ui.view">
        <field name="name">equipment.qc.template.list</field>
        <field name="model">equipment.qc.template</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="stage_type"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_equipment_qc_template" model="ir.actions.act_window">
        <field name="name">QC Checklist Templates</field>
        <field name="res_model">equipment.qc.template</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
