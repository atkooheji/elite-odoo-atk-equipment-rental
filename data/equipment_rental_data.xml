<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <!-- Rental Order Sequence -->
    <record id="seq_equipment_rental" model="ir.sequence">
        <field name="name">Equipment Rental</field>
        <field name="code">equipment.rental</field>
        <field name="prefix">RENT/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <!-- Operator Service Product -->
    <record id="product_operator_service" model="product.product">
        <field name="name">Operators</field>
        <field name="type">service</field>
        <field name="list_price">10.0</field>
        <field name="default_code">OPERATOR</field>
    </record>

</odoo>
