<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
        <record id="ir_cron_rental_return_reminder" model="ir.cron">
            <field name="name">Equipment Rental: 24h Return Reminder (Strategic)</field>
            <field name="model_id" ref="model_equipment_rental"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_return_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_rental_review_request" model="ir.cron">
            <field name="name">Equipment Rental: Post-Return Review Request (nl3ab 26)</field>
            <field name="model_id" ref="model_equipment_rental"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_review_requests()</field>
            <field name="interval_number">4</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
</odoo>
