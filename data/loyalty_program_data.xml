<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        Registry Fix: Satisfaction of loyalty record constraints. 
        We must include at least one reward to bypass the 'A program must have at least one reward' validation error during the module cleanup.
        You can Archive this program via the backend if you do not want it active.
    -->
    <record id="loyalty_program_normal_games" model="loyalty.program">
        <field name="name">Normal Games Bulk Rewards</field>
        <field name="program_type">promotion</field>
        <field name="applies_on">current</field>
        <field name="trigger">auto</field>
        <field name="active" eval="False"/> <!-- INACTIVE by default to prevent usage -->
    </record>

    <record id="loyalty_reward_normal_placeholder" model="loyalty.reward">
        <field name="program_id" ref="loyalty_program_normal_games"/>
        <field name="reward_type">product</field>
        <field name="required_points">9999</field>
        <field name="description">Cleanup Placeholder (Do not use)</field>
    </record>
</odoo>
